# wg-rsync.sh configuration -- copy to .env (gitignored) and edit.
#
# After ./setup.sh, most of this is unnecessary -- setup.sh writes
# state/network.env with SRC_USER, SRC_HOST, WG_PORT, etc. detected/prompted
# at install time. You normally only set SRC_PATHS and DST_DIR here.
#
# Precedence (high -> low):
#   pre-set env -> --env FILEs -> $PWD/.env -> $SCRIPT_DIR/.env ->
#   state/network.env (set by setup.sh) -> built-in defaults

# ---- what to transfer (you'll usually set this in .env or pass on CLI) ----
# Comma-separated absolute paths on source. Each is synced into
# $DST_DIR/<basename>/. Positional args to wg-rsync.sh override this.
# Example: SRC_PATHS=/volume2/Media/TV,/volume2/Media/Movies
SRC_PATHS=
DST_DIR=

# ---- source overrides (only if state/network.env values are wrong) -------
# SRC_USER=
# SRC_HOST=
# SRC_PORT=22
# SRC_SSH_OPTS=
# SRC_SSH_PWFILE= # default: ./state/src-ssh-pwd (set by setup.sh)

# ---- destination user (default: $USER) -----------------------------------
# DST_USER=

# ---- WireGuard overrides (only if state/network.env values are wrong) ----
# WG_IFACE=wg0
# WG_DST_ADDR=10.99.0.1
# WG_CLIENT_CONF=          # default: ./state/wg/wg-client.conf
# WG_CLIENT_CONF_REMOTE=/tmp/wg-rsync-client.conf
# SRC_SSH_KEY=             # default: ./state/ssh/src-key
# SRC_SSH_KEY_REMOTE=/tmp/wg-rsync-key

# ---- container -----------------------------------------------------------
# IMAGE=wg-rsync:latest
# ENGINE=                  # autodetect docker/podman
# ENGINE_SUDO=             # set to "sudo" if source needs sudo to run engine
# CONTAINER_NAME_PREFIX=wg-rsync

# ---- behavior -----------------------------------------------------------
# LOG_DIR=$HOME/wg-rsync-logs
# EXCLUDES=@eaDir,#recycle,.DS_Store,Thumbs.db
# RSYNC_FLAGS=-ahr --partial --partial-dir=.rsync-partial --info=stats2,progress2 --human-readable --timeout=600
# HEARTBEAT_INTERVAL=30
# PROGRESS_INTERVAL=10
# FORCE_BOOTSTRAP=0        # 1 = re-push conf/key and rebuild image
# DRY_RUN=0
# SKIP_AUTHKEY_CHECK=0     # 1 = skip authorized_keys preflight on destination
# SRC_PUBLIC_IP=           # autodetect via curl ifconfig.me
# BUCKET_DIR_REMOTE=/tmp
